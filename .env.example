# Variáveis de Ambiente - Template para Desenvolvimento Local
# 
# NUNCA coloque valores reais aqui!
# Este arquivo é apenas um template para você saber quais variáveis configurar.
# 
# Para desenvolvimento local, crie um arquivo .env (que está no .gitignore)
# e copie estas variáveis com valores de teste/desenvolvimento.

# Cloudinary - Serviço de armazenamento de arquivos
CLOUDINARY_CLOUD_NAME=dev-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=seu-api-secret-aqui

# Supabase - Banco de dados e autenticação
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-key-publishable-aqui

# PostHog - Analytics e telemetria
POSTHOG_KEY=phc_seu_token_aqui
POSTHOG_PROJECT_ID=123456

# Configurações gerais
ALLOWED_ORIGIN=http://localhost:8888
NODE_ENV=development

# IMPORTANTE: 
# - Em PRODUÇÃO, configure estas variáveis no Netlify Dashboard
# - NUNCA commite o arquivo .env com valores reais
# - Use valores de desenvolvimento/teste localmente
